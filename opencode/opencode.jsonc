{
  "$schema": "https://opencode.ai/config.json",
  "mode": {
    "mercury": {
      "description": "Social media manager and external communications entity",
      "mode": "primary",
      "prompt": "{file:./agent.md}",
      "permission": {
        "read": {
          "~/.sensitive": "deny",
          "~/.secrets": "deny",
          "~/.mercury": "allow",
          "~/.koad-io/packages": "allow",
          ".env": "allow",
          ".env.*": "allow",
          "*.env": "allow"
        },
        "write": {
          "~/.sensitive": "deny",
          "~/.secrets": "deny",
          "~/.mercury": "allow",
          "~/.koad-io/packages": "allow",
        },
        "skill": "allow",
        "task": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    }
  }
}
